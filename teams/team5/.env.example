# =============================================================================
# IKNL Cancer Information Chat — Environment Configuration
# Copy this file to .env and fill in the values
# =============================================================================

# Required: Anthropic API key for Claude LLM
ANTHROPIC_API_KEY=your-key-here

# LLM provider: "anthropic" (primary) or "ollama" (fallback)
LLM_PROVIDER=anthropic

# LLM model to use
LLM_MODEL=claude-sonnet-4-20250514

# Embedding model (default: all-MiniLM-L6-v2 for fast CPU inference)
# Override with "intfloat/multilingual-e5-large" for better Dutch quality (needs GPU)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Ollama base URL (only needed if LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434

# --- Port Configuration ---
BACKEND_PORT=8001
FRONTEND_PORT=3002

# Public URL the frontend uses to reach the backend API
# In production with a reverse proxy, use the public domain
NEXT_PUBLIC_API_URL=https://iknl.datameesters.nl

# --- Data Paths ---
CHROMADB_PATH=data/chromadb
FEEDBACK_DB_PATH=data/feedback.db
KANKER_NL_JSON_PATH=data/kanker_nl_pages_all.json
SITEMAP_PATH=data/sitemap.json
